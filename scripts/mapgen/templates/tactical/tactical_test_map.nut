				local wy = _rect.Y + y;
				local tile = this.Tactical.getTileSquare(wx, wy);
				// Set height first
				tile.Level = heightMap[y][x];
				// Stamp terrain
				local code = terrainMap[y][x];
				local rect = { X = wx, Y = wy, W = 1, H = 1, IsEmpty = false };
